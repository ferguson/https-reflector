{
  "name": "https-reflector",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferguson/https-reflector.git"
  },
  "author": "Jon Ferguson <jon@jef.us>",
  "description": "HTTPS Reflector",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "yarn build-client; yarn build-server",
