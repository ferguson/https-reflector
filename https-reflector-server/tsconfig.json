{
  "compilerOptions": {
    "target": "es5",
    "lib": ["ES2015"],
    "allowJs": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "strictNullChecks": false,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "isolatedModules": false,
    "outDir": "build",
    "types": ["node"],
  },
  "include": ["src/**/*.ts"],
}
