# Hostname(s) to serve — comma-separated, wildcards OK
HTTPS_REFLECTOR_HOSTNAME=*.otto.stream,*.mitlivinglabs.org

# TLS certificate paths (mounted from /etc/letsencrypt above)
HTTPS_REFLECTOR_PRIVATE_KEY_FILE=/etc/letsencrypt/live/otto.stream/privkey.pem
HTTPS_REFLECTOR_CERTIFICATE_FILE=/etc/letsencrypt/live/otto.stream/cert.pem
HTTPS_REFLECTOR_AUTHORITY_FILE=/etc/letsencrypt/live/otto.stream/chain.pem

# Status dashboard WebSocket — leave blank for no password
HTTPS_REFLECTOR_STATUS_PASSWORD=

# Internal paths (match the volume mounts in docker-compose.yml)
HTTPS_REFLECTOR_DATA_DIR=/data
HTTPS_REFLECTOR_PUBLIC_STATIC_DIR=/var/www/public
